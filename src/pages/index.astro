---
import { SITE_TITLE, SITE_TAGLINE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import Ava from '@src/assets/img/me.png';
import Prose from '../components/Prose.astro';
import { projects } from './projects/projects';
import ProjectList from '../components/ProjectList.astro';
import PostItem from '../components/PostItem.astro';

const top6Projects = projects.slice(0, 6);
const blogPosts = await getCollection('blog');
const writings = await getCollection('writings');
const allPosts = [...blogPosts, ...writings]
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 5);
---

<BaseLayout title={SITE_TITLE + ' - ' + SITE_TAGLINE} description={SITE_DESCRIPTION}>
	<div class='container'>
		<div class='w-full md:flex md:items-center gap-16 mb-10'>
			<div class='text-pretty leading-9'>
				<h1 class='text-4xl font-bold mb-4'>¡Hola! Soy Raksodiano</h1>
				<Prose>
					<div class='text-lg'>
						<p>
							¡Qué tal! Soy ingeniero en informática y un entusiasta total de la tecnología. Me paso el día buscando formas de automatizar
							procesos para hacernos la vida un poquito más fácil y promoviendo el conocimiento libre.
						</p>
						<p>
							Siempre con un buen café como combustible y nuevos desafíos en el horizonte, disfruto transformando ideas complejas en
							realidades brillantes.
						</p>
					</div>
				</Prose>
			</div>
			<Image src={Ava} alt='Raksodiano' width={300} loading='eager' class='rounded-3xl rotate-3 mx-4 md:mx-0' />
		</div>
		<main>
			<div class='mt-6 mb-12'>
				<div class='flex justify-between gap-2 border-b mb-1 dark:border-b-zinc-700'>
					<h2 class='text-lg font-bold mb-3'>Artículos recientes</h2>
					<a href={`${import.meta.env.BASE_URL}/posts/`} class='inline-block py-2 underline dark:prose-invert'
						>Todos los artículos &raquo;</a
					>
				</div>
				<div>
					{allPosts.map((post) => <PostItem post={post} />)}
				</div>
				<div class='text-right'></div>
			</div>
			<div>
				<div class='flex justify-between gap-2 mb-1'>
					<h2 class='text-lg font-bold mb-3'>Proyectos</h2>
					<a href={`${import.meta.env.BASE_URL}/projects/`} class='inline-block py-2 underline dark:prose-invert'
						>Todos los proyectos &raquo;</a
					>
				</div>
				<ProjectList projects={top6Projects} />
			</div>
		</main>
	</div>
</BaseLayout>
